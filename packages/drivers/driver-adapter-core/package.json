{
  "name": "@rawsql-ts/driver-adapter-core",
  "version": "0.1.0",
  "description": "Thin SQL driver adapter primitives for SQL-first rawsql-ts projects.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "msugiura",
  "repository": {
    "type": "git",
    "url": "https://github.com/mk3008/rawsql-ts.git",
    "directory": "packages/drivers/driver-adapter-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @rawsql-ts/shared-binder run build && tsc -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "test:consumer-validation": "vitest run --config vitest.config.ts",
    "lint": "eslint src --ext .ts",
    "prepack": "node -e \"const fs=require('fs');const cp=require('child_process');const npm=process.platform==='win32'?'npm.cmd':'npm';if(!fs.existsSync('dist/index.js')){process.exit(cp.spawnSync(npm,['run','build'],{stdio:'inherit'}).status??1)}\"",
    "release": "npm run lint && npm run test && npm run build && node -e \"require('fs').mkdirSync('../../../tmp', { recursive: true })\" && pnpm pack --out ../../../tmp/rawsql-ts-driver-adapter-core.tgz && pnpm publish --access public"
  },
  "dependencies": {
    "@rawsql-ts/shared-binder": "^0.0.1"
  },
  "files": [
    "dist"
  ]
}
