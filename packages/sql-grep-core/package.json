{
  "name": "@rawsql-ts/sql-grep-core",
  "version": "0.1.3",
  "description": "Low-dependency SQL usage analysis engine for rawsql-ts workspaces.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "pnpm --filter rawsql-ts build && tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint src --ext .ts --ignore-pattern \"*.d.ts\"",
    "release": "npm run lint && npm run test && npm run build && node -e \"require('fs').mkdirSync('../../tmp', { recursive: true })\" && pnpm pack --out ../../tmp/rawsql-ts-sql-grep-core.tgz && pnpm publish --access public"
  },
  "keywords": [
    "rawsql-ts",
    "sql",
    "grep",
    "ast",
    "analysis"
  ],
  "license": "MIT",
  "author": "msugiura",
  "repository": {
    "type": "git",
    "url": "https://github.com/mk3008/rawsql-ts.git",
    "directory": "packages/sql-grep-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "rawsql-ts": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^4.0.7"
  },
  "files": [
    "dist"
  ]
}
