{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "composite": false,
    "paths": {
      "rawsql-ts": ["../core/dist/src/index.d.ts"],
      "rawsql-ts/*": ["../core/dist/src/*"]
    },
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
