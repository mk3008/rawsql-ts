  "views": [
    {
      "id": "transfer-execution-main",
      "name": "Transfer Execution Main",
      "processMap": "transfer-execution",
      "relatedConcepts": [
        "transfer-execution"
      ],
      "purpose": "メインルーチンの状態遷移。実行文脈を作成し、判断材料を持つ Work Item を準備し、重複無視や no-op は転送をスキップし、転送が必要な場合は転送モデルで分岐し、順序付きの転送プロセスを実行し、結果を記録して終了する。"
    },
    {
      "id": "create-transfer-run",
      "name": "Create Transfer Run detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "transfer-setting"
        }
      ],
      "outputs": [
        {
          "type": "concept",
          "id": "transfer-run"
        }
      ],
      "relatedConcepts": [
        "transfer-run"
      ],
      "purpose": "Create Transfer Run が実行文脈を作成することを示す明細。"
    },
    {
      "id": "work-item-preparation",
      "name": "Prepare Work Item detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "dirty-key"
        },
        {
          "type": "concept",
          "id": "dirty-key-processing"
        },
        {
          "type": "concept",
          "id": "transfer-setting"
        },
        {
          "type": "concept",
          "id": "destination-link"
        },
        {
          "type": "concept",
          "id": "destination"
        },
        {
          "type": "concept",
          "id": "active-black"
        }
      ],
      "outputs": [
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "relatedConcepts": [
        "work-item"
      ],
      "purpose": "Prepare Work Item が Dirty Key を Work Item として固定し、処理済み Dirty Key を除外し、転送モデルのルートと転送作用の判断に必要な材料を付与することを示す明細。"
    },
    {
      "id": "red-transfer-insert",
      "name": "Red Transfer - insert detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "outputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        },
        {
          "type": "concept",
          "id": "lineage"
        }
      ],
      "uses": [
        {
          "type": "concept",
          "id": "red-transfer"
        }
      ],
      "relatedConcepts": [
        "red-transfer",
        "lineage"
      ],
      "purpose": "Red Transfer - insert が、Work Item の材料が Red Transfer を満たす場合に、反転する赤伝の転送先行を書き込み、Lineage を記録することを示す明細。"
    },
    {
      "id": "black-transfer-insert",
      "name": "Black Transfer - insert detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "outputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        },
        {
          "type": "concept",
          "id": "lineage"
        }
      ],
      "uses": [
        {
          "type": "concept",
          "id": "black-transfer"
        }
      ],
      "relatedConcepts": [
        "black-transfer",
        "lineage"
      ],
      "purpose": "Black Transfer - insert が、Work Item の材料が Black Insert Transfer を満たす場合に、黒伝の転送先行を書き込み、Lineage を記録することを示す明細。"
    },
    {
      "id": "physical-delete-transfer-execute",
      "name": "Physical Delete Transfer - execute detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "outputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        }
      ],
      "uses": [
        {
          "type": "concept",
          "id": "physical-delete-transfer"
        }
      ],
      "relatedConcepts": [
        "physical-delete-transfer"
      ],
      "purpose": "Physical Delete Transfer - execute が、Work Item の材料が Physical Delete Transfer を満たす場合に、転送先行を物理削除することを示す明細。"
    },
    {
      "id": "black-transfer-upsert",
      "name": "Black Transfer - upsert detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "outputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        }
      ],
      "uses": [
        {
          "type": "concept",
          "id": "black-transfer"
        }
      ],
      "relatedConcepts": [
        "black-transfer"
      ],
      "purpose": "Black Transfer - upsert が、Work Item の材料が mutable Black Transfer を満たす場合に、転送先行を追加または更新することを示す明細。"
    },
    {
      "id": "record-processing-result",
      "name": "Record Processing Result detail",
      "processMap": "transfer-execution",
      "inputs": [
        {
          "type": "concept",
          "id": "transfer-run"
        },
        {
          "type": "concept",
          "id": "work-item"
        }
      ],
      "outputs": [
        {
          "type": "concept",
          "id": "dirty-key-processing"
        }
      ],
      "relatedConcepts": [
        "dirty-key-processing"
      ],
      "purpose": "Record Processing Result が、二重転送防止のために Dirty Key Processing へ処理結果を記録することを示す明細。"
    },
    {
      "id": "lineage-audit",
      "name": "Trace Origin From Destination Row flow",
      "processMap": "lineage-trace",
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "Lineage の照合と由来照会結果を通じて、転送先行の由来を追跡するフロー。"
    },
    {
      "id": "resolve-lineage-match",
      "name": "Resolve Lineage Match detail",
      "processMap": "lineage-trace",
      "inputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        },
        {
          "type": "concept",
          "id": "lineage"
        }
      ],
      "outputs": [
        {
          "type": "derived-view",
          "id": "matched-lineage-row"
        }
      ],
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "Resolve Lineage Match が、Lineage を持つ転送先行を起点に Matched Lineage Row を作ることを示す明細。"
    },
    {
      "id": "build-origin-context",
      "name": "Build Origin Context detail",
      "processMap": "lineage-trace",
      "inputs": [
        {
          "type": "derived-view",
          "id": "matched-lineage-row"
        },
        {
          "type": "concept",
          "id": "transfer-run"
        },
        {
          "type": "concept",
          "id": "transfer-setting"
        },
        {
          "type": "concept",
          "id": "destination-link"
        }
      ],
      "outputs": [
        {
          "type": "derived-view",
          "id": "origin-trace-view"
        }
      ],
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "Build Origin Context が、Matched Lineage Row を使って source key、実行文脈、Transfer Setting、Destination Link の文脈を Origin Trace View に集めることを示す明細。"
    },
    {
      "id": "lineage-history",
      "name": "Trace Destination Row History flow",
      "processMap": "lineage-trace",
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "履歴文脈と転送先行履歴の照会結果を通じて、転送先行の履歴を追跡するフロー。"
    },
    {
      "id": "resolve-history-context",
      "name": "Resolve Lineage History detail",
      "processMap": "lineage-trace",
      "inputs": [
        {
          "type": "external-store",
          "id": "destination-table"
        },
        {
          "type": "concept",
          "id": "lineage"
        }
      ],
      "outputs": [
        {
          "type": "derived-view",
          "id": "lineage-history-key-list"
        }
      ],
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "Resolve Lineage History が、Lineage を持つ転送先行を起点に、同じ source key と Destination Link の文脈にある関連 Lineage と転送先行の Lineage History Key List を作ることを示す明細。"
    },
    {
      "id": "build-destination-row-history-view",
      "name": "Build Destination Row History View detail",
      "processMap": "lineage-trace",
      "inputs": [
        {
          "type": "derived-view",
          "id": "lineage-history-key-list"
        },
        {
          "type": "external-store",
          "id": "destination-table"
        }
      ],
      "outputs": [
        {
          "type": "derived-view",
          "id": "destination-row-history-view"
        }
      ],
      "relatedConcepts": [
        "lineage"
      ],
      "purpose": "Build Destination Row History View が、Lineage History Key List と destination table の行から、読み取り専用の転送先行履歴照会結果を作ることを示す明細。"
    }
  ]
}
