{
  "schemaVersion": 2,
  "id": "active-black",
  "displayName": "有効黒伝",
  "lifecycle": {
    "status": "defined"
  },
  "definition": {
    "summary": "転送済みの黒伝のうち、まだ取り消されていない現在有効な黒伝。",
    "statements": [
      {
        "id": "active-black-is-current-black",
        "polarity": "positive",
        "type": "essence",
        "text": "Active Black は、転送済みの黒伝のうち、まだ取り消されていない現在有効な黒伝である。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "現在有効な黒伝"
      },
      {
        "id": "black-row-background",
        "polarity": "positive",
        "type": "rationale",
        "text": "黒伝とは、転送元データをそのまま転送先へ流した転送先行である。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "黒伝の前提"
      },
      {
        "id": "not-source-row",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、転送元行そのものではなく、転送済みの黒伝を指す。",
        "negatesSimilarityWith": [
          "source-row"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "転送元行ではない"
      },
      {
        "id": "context-is-transfer-setting-destination-link-source-key",
        "polarity": "positive",
        "type": "essence",
        "text": "Active Black は、Transfer Setting と Destination Link の文脈で、source key に対する現在有効な黒伝を示す。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "文脈単位"
      },
      {
        "id": "decision-material",
        "polarity": "positive",
        "type": "responsibility",
        "text": "Active Black は、二重転送防止、更新相当の転送、取消や訂正の判断材料として参照される。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "転送判断材料"
      },
      {
        "id": "identify-current-black",
        "polarity": "positive",
        "type": "responsibility",
        "text": "現在有効な黒伝を特定できるようにする。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "有効黒伝の特定"
      },
      {
        "id": "identify-red-transfer-target",
        "polarity": "positive",
        "type": "responsibility",
        "text": "immutable transfer model の Red Transfer で反転対象として参照すべき黒伝を特定できるようにする。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "赤伝の反転対象特定"
      },
      {
        "id": "provide-validity-boundary",
        "polarity": "positive",
        "type": "responsibility",
        "text": "転送済みの黒伝がまだ有効かどうかを判断するための概念境界を提供する。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "有効性境界"
      },
      {
        "id": "represent-disappearance-after-cancel",
        "polarity": "positive",
        "type": "responsibility",
        "text": "黒伝が Red Transfer または Physical Delete Transfer によって取り消された後には存在しない状態を表現する。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "取消後の不存在"
      },
      {
        "id": "support-lineage-trace",
        "polarity": "positive",
        "type": "responsibility",
        "text": "Lineage と併用される場合、反転対象となる転送先行を追跡しやすくする。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Lineage追跡補助"
      },
      {
        "id": "not-lineage-management",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、転送先行の由来追跡を管理しない。",
        "negatesSimilarityWith": [
          "lineage"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Lineage管理ではない"
      },
      {
        "id": "not-work-item-selection",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、転送対象行を決定しない。",
        "negatesSimilarityWith": [
          "work-item"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "転送対象決定ではない"
      },
      {
        "id": "not-transfer-state",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、転送依頼、転送実行、または転送処理状態を管理しない。",
        "negatesSimilarityWith": [
          "transfer-execution",
          "transfer-run"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "転送状態管理ではない"
      },
      {
        "id": "not-red-transfer-definition",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、Red Transfer の意味を定義しない。",
        "negatesSimilarityWith": [
          "red-transfer"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Red Transfer定義ではない"
      },
      {
        "id": "not-sql-or-calculation",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、赤伝 SQL の生成手順、実行手順、黒伝や赤伝の金額計算、符号反転列、列マッピングを定義しない。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "SQLや計算式ではない"
      },
      {
        "id": "not-mutable-log",
        "polarity": "negative",
        "type": "boundary",
        "text": "Active Black は、mutable transfer model の処理ログや監査ログではない。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "mutableログではない"
      },
      {
        "id": "requires-transferred-black",
        "polarity": "positive",
        "type": "invariant",
        "text": "Active Black は、転送済みの黒伝が存在する場合にだけ存在し得る。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "転送済み黒伝が必要"
      },
      {
        "id": "unique-per-context",
        "polarity": "positive",
        "type": "invariant",
        "text": "Active Black は、Transfer Setting と Destination Link の文脈における source key 単位で最大1つである。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "文脈内で最大1つ"
      },
      {
        "id": "none-for-unlinked-source",
        "polarity": "negative",
        "type": "invariant",
        "text": "連携されていない転送元行には Active Black は存在しない。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "未連携なら存在しない"
      },
      {
        "id": "none-for-cancelled-black",
        "polarity": "negative",
        "type": "invariant",
        "text": "取り消し済みの黒伝には Active Black は存在しない。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "取消済みなら存在しない"
      },
      {
        "id": "red-transfer-removes-active-black",
        "polarity": "positive",
        "type": "invariant",
        "text": "immutable transfer model では、Red Transfer が成功したタイミングで、反転対象だった黒伝は Active Black ではなくなる。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "赤伝後は非Active"
      },
      {
        "id": "new-black-becomes-active",
        "polarity": "positive",
        "type": "invariant",
        "text": "immutable transfer model で赤伝後に新しい黒伝が追加された場合、その新しい黒伝が Active Black になる。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "新黒伝がActiveになる"
      },
      {
        "id": "physical-delete-removes-active-black",
        "polarity": "positive",
        "type": "invariant",
        "text": "mutable transfer model では、Physical Delete Transfer が成功したタイミングで、対応する黒伝は Active Black ではなくなる。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "物理削除後は非Active"
      },
      {
        "id": "separate-axis-from-lineage",
        "polarity": "positive",
        "type": "boundary",
        "text": "Active Black は、現在有効な黒伝を示す別軸の概念である。",
        "negatesSimilarityWith": [
          "lineage"
        ],
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Lineageとは別軸"
      },
      {
        "id": "red-transfer-needs-active-black",
        "polarity": "positive",
        "type": "rationale",
        "text": "immutable transfer model で Red Transfer を行うには、どの黒伝を反転するかを特定する必要がある。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "赤伝が必要とする理由"
      },
      {
        "id": "destination-link-context-rationale",
        "polarity": "positive",
        "type": "rationale",
        "text": "同じ Transfer Setting と source key から複数の Destination Link へ転送する場合、Active Black は Destination Link の文脈ごとに区別する。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Destination Link別の理由"
      },
      {
        "id": "lineage-is-related-but-separate",
        "polarity": "positive",
        "type": "rationale",
        "text": "Lineage は immutable transfer model における転送先行の由来追跡であり、Active Black は現在有効な黒伝を示す。両者は併用されることがあるが、役割は異なる。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "Lineageとの関係理由"
      },
      {
        "id": "transfer-model-changes-when-active-black-disappears",
        "polarity": "positive",
        "type": "rationale",
        "text": "immutable transfer model では Red Transfer が成功したタイミングで、mutable transfer model では Physical Delete Transfer が成功したタイミングで、対象だった Active Black は存在しなくなる。",
        "evidence": [
          "spec:active-black"
        ],
        "displayName": "モデル別に消える理由"
      }
    ]
  },
